# Жишээ .env — бодит утгуудаар нөхөж .env нэрээр хадгална
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=milo
DB_PASSWORD=your_password_here
DB_NAME=milo_kali

PORT=4000

JWT_SECRET=replace_with_a_long_random_string

# Frontend build: деплой хийсэн backend-ийн бүрэн хаяг.
# Хоосон бол dev дээр vite /api-г localhost:4000 руу proxy хийнэ.
# Жишээ (production): VITE_API_URL=https://my-api.onrender.com
VITE_API_URL=
